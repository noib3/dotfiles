Makes model discovery advertise models available to any pooled account, so
Codex receives metadata for models supported through account fallback.

---
diff --git a/app/core/openai/model_refresh_scheduler.py b/app/core/openai/model_refresh_scheduler.py
index 880448c..15f5677 100644
--- a/app/core/openai/model_refresh_scheduler.py
+++ b/app/core/openai/model_refresh_scheduler.py
@@ -250,20 +250,14 @@ def _merge_same_plan_model_results(successful_results: list[list[UpstreamModel]]
     if not successful_results:
         return []

-    models_by_slug = [{model.slug: model for model in models} for models in successful_results]
-    common_slugs = set(models_by_slug[0])
-    for models in models_by_slug[1:]:
-        common_slugs.intersection_update(models)
-
-    merged_models: list[UpstreamModel] = []
-    for model in models_by_slug[0].values():
-        if model.slug not in common_slugs:
-            continue
-        merged_model = model
-        for models in models_by_slug[1:]:
-            merged_model = _merge_service_tier_metadata(merged_model, models[model.slug])
-        merged_models.append(merged_model)
-    return merged_models
+    merged_models: dict[str, UpstreamModel] = {}
+    for models in successful_results:
+        for model in models:
+            existing = merged_models.get(model.slug)
+            merged_models[model.slug] = (
+                model if existing is None else _merge_service_tier_metadata(existing, model)
+            )
+    return list(merged_models.values())


 async def _ensure_fresh_with_transport_recovery(
