Enables transparent fallback to another pooled account when upstream rejects
the requested model for the account initially selected by codex-lb.

---
diff --git a/app/modules/proxy/_service/websocket/mixin.py b/app/modules/proxy/_service/websocket/mixin.py
index 4c17ada..af212ff 100644
--- a/app/modules/proxy/_service/websocket/mixin.py
+++ b/app/modules/proxy/_service/websocket/mixin.py
@@ -448,6 +448,21 @@ def _facade() -> Any:
     return sys.modules["app.modules.proxy.service"]


+def _is_account_scoped_model_unsupported_error(code: str | None, message: str | None) -> bool:
+    """Return whether upstream rejected a model for the selected ChatGPT account.
+
+    Model rollouts can differ between accounts on the same plan.  Treat only
+    the backend's exact account-scoped rejection as eligible for transparent
+    failover; other invalid requests remain terminal.
+    """
+    if code != "invalid_request_error" or not isinstance(message, str):
+        return False
+    normalized = message.strip().lower()
+    return normalized.startswith("the '") and normalized.endswith(
+        "' model is not supported when using codex with a chatgpt account."
+    )
+
+
