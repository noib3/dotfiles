+import { describe, expect, test } from "bun:test"
+import { Usage } from "../../src/usage"
+
+describe("copilot usage fallback", () => {
+  test("keeps zero quota from token metadata", async () => {
+    const originalFetch = globalThis.fetch
+
+    globalThis.fetch = ((input: RequestInfo | URL) => {
+      const url = input.toString()
+      if (url === "https://api.github.com/copilot_internal/user") {
+        return Promise.resolve(new Response("", { status: 500 }))
+      }
+      return Promise.resolve(new Response("", { status: 404 }))
+    }) as typeof fetch
+
+    try {
+      const result = await Usage.fetchCopilotUsage({
+        access: "sku=copilot_for_individual;cq=0",
+        refresh: "copilot-refresh",
+        usage: "copilot-usage-token",
+      })
+
