 export const defaultLayer = layer.pipe(Layer.provide(AppFileSystem.defaultLayer))
 
+function runPromise<T>(fn: (service: Interface) => Effect.Effect<T, AuthError>) {
+  return Effect.runPromise(Effect.gen(function* () {
+    const service = yield* Service
+    return yield* fn(service)
+  }).pipe(Effect.provide(defaultLayer)))
+}
+
+export async function get(providerID: string, profileID?: string) {
+  return runPromise((service) => service.get(providerID, profileID))
+}
+
+export async function all() {
+  return runPromise((service) => service.all())
+}
+
+export async function allWithProfiles() {
+  return runPromise((service) => service.allWithProfiles())
+}
+
+export async function set(key: string, info: Info) {
+  return runPromise((service) => service.set(key, info))
+}
+
+export async function remove(key: string) {
+  return runPromise((service) => service.remove(key))
+}
+
+export async function addProfile(providerID: string, profileID: string, info: Info) {
+  return runPromise((service) => service.addProfile(providerID, profileID, info))
+}
+
+export async function removeProfile(providerID: string, profileID: string) {
+  return runPromise((service) => service.removeProfile(providerID, profileID))
+}
+
+export async function setActiveProfile(providerID: string, profileID: string, opts?: { create?: boolean }) {
+  return runPromise((service) => service.setActiveProfile(providerID, profileID, opts))
+}
+
+export async function listProfiles(providerID: string) {
+  return runPromise((service) => service.listProfiles(providerID))
+}
+
+export async function renameProfile(providerID: string, oldName: string, newName: string) {
+  return runPromise((service) => service.renameProfile(providerID, oldName, newName))
+}
