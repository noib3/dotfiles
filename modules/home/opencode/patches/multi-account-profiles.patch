+
+export function DialogProfile() {
+  const sdk = useSDK()
+  const sync = useSync()
+  const local = useLocal()
+  const dialog = useDialog()
+
+  const providerID = createMemo(() => local.model.current()?.providerID ?? "")
+  const name = createMemo(() => local.model.parsed().provider)
+
+  const [version, setVersion] = createSignal(0)
+
+  const [profiles] = createResource(
+    () => ({ id: providerID(), v: version() }),
+    async ({ id }) => {
+      if (!id) return undefined
+      const res = await sdk.fetch(`${sdk.url}/auth/${encodeURIComponent(id)}/profiles`)
+      if (!res.ok) return undefined
+      return (await res.json()) as { profiles: string[]; active?: string }
+    },
+  )
+
+  const options = createMemo(() => {
+    const data = profiles()
+    if (!data) return []
+    return data.profiles.map((p: string) => ({
+      value: p,
+      title: p,
+      description: p === data.active ? "active" : undefined,
+    }))
+  })
+
+  return (
+    <DialogSelect
+      title={`Switch profile \u00b7 ${name()}`}
+      current={profiles()?.active}
+      options={options()}
+      onSelect={async (option) => {
+        const id = providerID()
+        await sdk.fetch(`${sdk.url}/auth/${encodeURIComponent(id)}/profile`, {
+          method: "PATCH",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify({ profileID: option.value }),
+        })
+        sync.set("active_profiles", id, option.value)
+        dialog.clear()
+      }}
+      keybind={[
+        {
+          keybind: { name: "r", ctrl: false, meta: false, shift: false, super: false, leader: false },
+          title: "rename",
+          onTrigger: (option) => {
+            dialog.replace(() => (
+              <DialogPrompt
+                title={`Rename "${option.value}"`}
+                placeholder="New name"
+                onConfirm={async (newName) => {
+                  if (!newName?.trim()) return
+                  const id = providerID()
+                  await sdk.fetch(`${sdk.url}/auth/${encodeURIComponent(id)}/profile/rename`, {
+                    method: "PATCH",
+                    headers: { "Content-Type": "application/json" },
+                    body: JSON.stringify({ oldName: option.value, newName: newName.trim() }),
+                  })
+                  if (sync.data.active_profiles[id] === option.value) {
+                    sync.set("active_profiles", id, newName.trim())
+                  }
+                  setVersion((v) => v + 1)
+                  dialog.replace(() => <DialogProfile />)
+                }}
+              />
+            ))
+          },
+        },
+      ]}
+    />
+  )
+}
