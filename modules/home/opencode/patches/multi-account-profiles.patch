+function normalizeProviderID(key: string) {
+  return key.replace(/\/+$/, "")
+}
+
+function normalizeToInternal(data: Record<string, unknown>, decode: (value: unknown) => Info | undefined) {
+  const result: Record<string, ProviderData> = {}
+  for (const [key, value] of Object.entries(data)) {
+    const providerID = normalizeProviderID(key)
+    if (value && typeof value === "object" && "profiles" in value && typeof (value as any).profiles === "object") {
+      const source = value as { profiles: Record<string, unknown>; currentProfile?: string }
+      const profiles: Record<string, Info> = {}
+      for (const [profileID, profileValue] of Object.entries(source.profiles)) {
+        const decoded = decode(profileValue)
+        if (decoded) profiles[profileID] = decoded
+      }
+      if (Object.keys(profiles).length > 0) result[providerID] = { profiles, currentProfile: source.currentProfile }
+      continue
+    }
+    const decoded = decode(value)
+    if (decoded) result[providerID] = { profiles: { default: decoded }, currentProfile: "default" }
+  }
+  return result
+}
+
+function flattenActive(data: Record<string, ProviderData>) {
+  const result: Record<string, Info> = {}
+  for (const [providerID, provider] of Object.entries(data)) {
+    const active = provider.currentProfile ?? Object.keys(provider.profiles)[0]
+    if (!active) continue
+    const info = provider.profiles[active]
+    if (info) result[providerID] = info
+  }
+  return result
+}
