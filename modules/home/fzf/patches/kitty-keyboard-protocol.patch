+func (r *LightRenderer) kittyKeySequence(sz *int) Event {
+	end := bytes.IndexByte(r.buffer[2:], 'u')
+	if end < 0 {
+		return Event{Invalid, 0, nil}
+	}
+
+	end += 2
+	params := strings.Split(string(r.buffer[2:end]), ";")
+	if len(params) == 0 || len(params) > 2 {
+		return Event{Invalid, 0, nil}
+	}
+
+	keyParam := strings.SplitN(params[0], ":", 2)[0]
+	key, err := strconv.Atoi(keyParam)
+	if err != nil {
+		return Event{Invalid, 0, nil}
+	}
+
+	modifier := 1
+	if len(params) == 2 {
+		modifier, err = strconv.Atoi(params[1])
+		if err != nil || modifier < 1 {
+			return Event{Invalid, 0, nil}
+		}
+	}
+
+	*sz = end + 1
+	mask := modifier - 1
+	shift := mask&1 != 0
+	ctrl := mask&4 != 0
+	alt := mask&2 != 0
+	super := mask&8 != 0
+
+	switch key {
+	case 57417:
+		return kittyArrowEvent(ctrl, alt, shift, super, Left, CtrlLeft, AltLeft, CtrlAltLeft, ShiftLeft, CtrlShiftLeft, AltShiftLeft, CtrlAltShiftLeft, SuperLeft)
+	case 57418:
+		return kittyArrowEvent(ctrl, alt, shift, super, Right, CtrlRight, AltRight, CtrlAltRight, ShiftRight, CtrlShiftRight, AltShiftRight, CtrlAltShiftRight, SuperRight)
+	case 57419:
+		return kittyArrowEvent(ctrl, alt, shift, super, Up, CtrlUp, AltUp, CtrlAltUp, ShiftUp, CtrlShiftUp, AltShiftUp, CtrlAltShiftUp, SuperUp)
+	case 57420:
+		return kittyArrowEvent(ctrl, alt, shift, super, Down, CtrlDown, AltDown, CtrlAltDown, ShiftDown, CtrlShiftDown, AltShiftDown, CtrlAltShiftDown, SuperDown)
+	case 27:
+		if !ctrl && !alt && !super {
+			return Event{Esc, 0, nil}
+		}
+	case 127:
+		if ctrl {
+			return Event{CtrlBackspace, 0, nil}
+		}
+		return Event{Backspace, 0, nil}
+	}
+
+	if ctrl {
+		switch key {
+		case ' ', '2':
+			return Event{CtrlSpace, 0, nil}
+		case '\\':
+			return Event{CtrlBackSlash, 0, nil}
+		case ']':
+			return Event{CtrlRightBracket, 0, nil}
+		case '^', '6':
+			return Event{CtrlCaret, 0, nil}
+		case '/', '_':
+			return Event{CtrlSlash, 0, nil}
+		}
+
+		if key >= 'A' && key <= 'Z' {
+			key += 'a' - 'A'
+		}
+		if key == 'h' {
+			return Event{CtrlBackspace, 0, nil}
+		}
+		if key >= 'a' && key <= 'z' {
+			if alt {
+				return CtrlAltKey(rune(key))
+			}
+			return Event{EventType(int(CtrlA) + key - 'a'), 0, nil}
+		}
+	}
+
+	if alt && key >= 0 && key <= utf8.MaxRune {
+		return AltKey(rune(key))
+	}
+	if !super && key >= 0 && key <= utf8.MaxRune {
+		return Event{Rune, rune(key), nil}
 	}
+
 	return Event{Invalid, 0, nil}
 }

+func kittyArrowEvent(ctrl bool, alt bool, shift bool, super bool, normal EventType, ctrlEvent EventType, altEvent EventType, ctrlAltEvent EventType, shiftEvent EventType, ctrlShiftEvent EventType, altShiftEvent EventType, ctrlAltShiftEvent EventType, superEvent EventType) Event {
+	if super && !ctrl && !alt {
+		return Event{superEvent, 0, nil}
+	}
+	if ctrl && alt && shift {
+		return Event{ctrlAltShiftEvent, 0, nil}
+	}
+	if ctrl && alt {
+		return Event{ctrlAltEvent, 0, nil}
+	}
+	if ctrl && shift {
+		return Event{ctrlShiftEvent, 0, nil}
+	}
+	if alt && shift {
+		return Event{altShiftEvent, 0, nil}
+	}
+	if ctrl {
+		return Event{ctrlEvent, 0, nil}
+	}
+	if alt {
+		return Event{altEvent, 0, nil}
+	}
+	if shift {
+		return Event{shiftEvent, 0, nil}
+	}
+	return Event{normal, 0, nil}
+}
+
