#!/usr/bin/env bash

real_nvim=${NVIM_FLATTEN_REAL_NVIM:-nvim}

if [[ -z ${NVIM:-} ]]; then
  exec "$real_nvim" "$@"
fi

files_only=true
after_double_dash=false

for arg in "$@"; do
  if [[ $arg == "--" ]]; then
    after_double_dash=true
    continue
  fi

  if [[ $after_double_dash == false && ($arg == -* || $arg == +*) ]]; then
    files_only=false
    break
  fi
done

[[ $files_only == true ]] || exec "$real_nvim" "$@"

filepaths=""
for arg in "$@"; do
  if filepath=$(realpath -m -- "$arg" 2>/dev/null); then
    :
  elif filepath=$(realpath "$arg" 2>/dev/null); then
    :
  elif [[ $arg == /* ]]; then
    filepath=$arg
  else
    filepath=$PWD/$arg
  fi

  escaped_filepath=${filepath//\\/\\\\}
  escaped_filepath=${escaped_filepath//\"/\\\"}
  filepaths+="\"$escaped_filepath\","
done

fifo=$(mktemp -u)
mkfifo "$fifo"
trap 'rm -f "$fifo"' EXIT

escaped_fifo=${fifo//\\/\\\\}
escaped_fifo=${escaped_fifo//\"/\\\"}

expr="luaeval('vim.api.nvim_exec_autocmds(\"User\", { pattern = \"NvimFlattenLaunch\", modeline = false, data = { filepaths = { $filepaths }, on_done = function() local f = io.open(\"$escaped_fifo\", \"w\"); if f then f:close() end end } })')"

if "$real_nvim" --server "$NVIM" --remote-expr "$expr" 2>/dev/null; then
  read -r <"$fifo" || true
  exit 0
fi

exec "$real_nvim" "$@"
