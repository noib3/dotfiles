#!/bin/sh

real_nvim=${NVIM_FLATTEN_REAL_NVIM:?nvim-flatten: real nvim is unset}
bin_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P) || exit
cli=$bin_dir/../lua/nvim_flatten/cli.lua

"$real_nvim" --clean -l "$cli" "$@"
status=$?

if [ "$status" -eq 125 ]; then
  exec "$real_nvim" "$@"
fi

exit "$status"
