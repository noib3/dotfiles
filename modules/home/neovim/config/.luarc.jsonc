{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "diagnostics": {
    "disable": [
      "codestyle-check",
      "redefined-local"
    ],
    "globals": ["vim"],
    "libraryFiles": "Disable"
  },
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "checkThirdParty": false,
    "ignoreDir": [".git"],
    "library": ["$VIMRUNTIME/lua", "$NVIM_PLUGINS"]
  }
}
